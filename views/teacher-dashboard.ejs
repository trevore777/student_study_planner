<h1>Teacher Dashboard</h1>

<p>Logged in as: <strong><%= teacher.name %></strong></p>

<form method="POST" action="/teacher/logout">
  <button type="submit">Logout</button>
</form>

<p>
  <a href="/teacher/classes/new">Add Class</a> |
  <a href="/teacher/homework/new">Post Homework</a>
</p>

<h2>My Classes</h2>

<% if (!classes.length) { %>
  <p>No classes yet.</p>
<% } else { %>
  <table border="1" cellpadding="8">
    <tr>
      <th>Class</th>
      <th>Year Level</th>
      <th>Created</th>
    </tr>

    <% classes.forEach((cls) => { %>
      <tr>
        <td><%= cls.name %></td>
        <td><%= cls.year_level %></td>
        <td><%= cls.created_at %></td>
      </tr>
    <% }) %>
  </table>
<% } %>

<h2>My Homework</h2>

<% if (!homeworkItems.length) { %>
  <p>No homework posted yet.</p>
<% } else { %>
  <table border="1" cellpadding="8">
    <tr>
      <th>Class</th>
      <th>Subject</th>
      <th>Title</th>
      <th>Due</th>
      <th>Minutes</th>
    </tr>

    <% homeworkItems.forEach((item) => { %>
      <tr>
        <td><%= item.class_name %></td>
        <td><%= item.subject %></td>
        <td><%= item.title %></td>
        <td><%= item.due_date %></td>
        <td><%= item.estimated_minutes %></td>
      </tr>
    <% }) %>
  </table>
<% } %>

<h2>Kings Credit Claims</h2>

<% if (!creditClaims.length) { %>
  <p>No claims yet.</p>
<% } else { %>
  <table border="1" cellpadding="8">
    <tr>
      <th>Student</th>
      <th>Year</th>
      <th>Days</th>
      <th>Status</th>
      <th>Action</th>
    </tr>

    <% creditClaims.forEach((claim) => { %>
      <tr>
        <td><%= claim.student_name %></td>
        <td><%= claim.year_level %></td>
        <td><%= claim.challenge_days %></td>
        <td><%= claim.status %></td>
        <td>
          <% if (claim.status === 'pending') { %>
            <form method="POST" action="/teacher/claims/<%= claim.id %>/approve" style="display:inline;">
              <button type="submit">Approve</button>
            </form>

            <form method="POST" action="/teacher/claims/<%= claim.id %>/reject" style="display:inline;">
              <button type="submit">Reject</button>
            </form>
          <% } %>
        </td>
      </tr>
    <% }) %>
  </table>
<% } %>