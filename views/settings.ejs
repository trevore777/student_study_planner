<section class="page-header">
  <div>
    <h1>My Setup</h1>
    <p class="lede">Choose your year level and classes so your dashboard only shows relevant homework.</p>
  </div>
</section>

<section class="grid dashboard-grid">
  <article class="card">
    <h2>Student profile</h2>

    <form id="studentProfileForm" class="stack-form">
      <div class="field">
        <label for="studentName">Student name</label>
        <input id="studentName" name="studentName" type="text" placeholder="e.g. Ernest" />
      </div>

      <div class="field">
        <label for="yearLevel">Year level</label>
        <input id="yearLevel" name="yearLevel" type="text" placeholder="e.g. 8" />
      </div>

      <div class="actions">
        <button class="button primary" type="submit">Save profile</button>
      </div>
    </form>
  </article>

  <article class="card">
    <h2>How this works</h2>
    <ul class="tight-list">
      <li>Enter your year level first</li>
      <li>The class list will filter to your year level</li>
      <li>Select the classes that belong to you</li>
      <li>Your dashboard will only show homework for those classes</li>
    </ul>
  </article>
</section>

<section class="card">
  <div class="section-heading">
    <h2>My classes</h2>
  </div>

  <div id="studentSetupStatus" class="muted" style="margin-bottom: 1rem;"></div>
  <div id="availableClassesList" class="task-list empty-state">
    <p>Loading classes...</p>
  </div>
</section>

<script src="/client/db.js"></script>
<script src="/client/setup.js"></script>