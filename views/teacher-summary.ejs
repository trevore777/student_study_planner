<%
  function formatDateAU(value) {
    if (!value) return 'No date';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;
    return date.toLocaleDateString('en-AU', {
      day: 'numeric',
      month: 'long',
      year: 'numeric'
    });
  }
%>

<section class="page-header">
  <div>
    <h1>Class Summary</h1>
    <p class="lede">Overview of published homework by school and class.</p>
  </div>
</section>

<section class="card">
  <%
    const grouped = {};
    homeworkItems.forEach(item => {
      const schoolKey = item.school_name || item.school_id || 'Unknown School';
      const classKey = item.class_name || item.class_id || 'Unknown Class';

      if (!grouped[schoolKey]) grouped[schoolKey] = {};
      if (!grouped[schoolKey][classKey]) grouped[schoolKey][classKey] = [];
      grouped[schoolKey][classKey].push(item);
    });

    const schoolNames = Object.keys(grouped).sort();
  %>

  <% if (!schoolNames.length) { %>
    <p>No homework data available yet.</p>
  <% } else { %>
    <div class="task-list">
      <% schoolNames.forEach(schoolName => { %>
        <article class="task-card">
          <h2><%= schoolName %></h2>

          <% Object.keys(grouped[schoolName]).sort().forEach(className => { %>
            <div style="margin-top: 1rem;">
              <h3><%= className %></h3>
              <ul class="tight-list">
                <% grouped[schoolName][className].forEach(item => { %>
                  <li>
                    <strong><%= item.subject %></strong> —
                    <%= item.title %>
                    (Due <%= formatDateAU(item.due_date) %>)
                  </li>
                <% }) %>
              </ul>
            </div>
          <% }) %>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>