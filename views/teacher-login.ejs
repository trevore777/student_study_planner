<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Teacher Login | StudyTrack</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f4f6f8;
      color: #222;
    }

    .login-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .card {
      width: 100%;
      max-width: 420px;
      background: white;
      border-radius: 14px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.08);
      padding: 32px;
    }

    h1 {
      margin: 0 0 8px;
      color: #1f4f8f;
    }

    .subtitle {
      margin-bottom: 24px;
      color: #666;
    }

    label {
      display: block;
      font-weight: bold;
      margin-top: 16px;
      margin-bottom: 6px;
    }

    input {
      width: 100%;
      padding: 12px;
      border: 1px solid #ccc;
      border-radius: 8px;
      font-size: 15px;
      box-sizing: border-box;
    }

    button {
      width: 100%;
      margin-top: 22px;
      padding: 13px;
      background: #1f4f8f;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
    }

    button:hover {
      background: #173d70;
    }

    .message {
      padding: 12px;
      border-radius: 8px;
      margin-bottom: 16px;
      font-size: 14px;
    }

    .error {
      background: #fdecec;
      color: #9b1c1c;
      border: 1px solid #f5b5b5;
    }

    .success {
      background: #ecfdf3;
      color: #166534;
      border: 1px solid #9ae6b4;
    }

    .link-button {
      background: none;
      color: #1f4f8f;
      border: none;
      padding: 0;
      margin-top: 18px;
      cursor: pointer;
      font-size: 14px;
      text-decoration: underline;
    }

    .reset-box {
      display: none;
      margin-top: 24px;
      border-top: 1px solid #eee;
      padding-top: 20px;
    }

    .small {
      font-size: 13px;
      color: #777;
      margin-top: 12px;
    }
  </style>
</head>

<body>
  <div class="login-wrap">
    <div class="card">
      <h1>Teacher Login</h1>
      <p class="subtitle">Sign in to manage homework, classes and Kings Credit.</p>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="message error"><%= error %></div>
      <% } %>

      <% if (typeof success !== "undefined" && success) { %>
        <div class="message success"><%= success %></div>
      <% } %>

      <form method="POST" action="/teacher/login">
        <label for="email">Email</label>
        <input 
          id="email" 
          name="email" 
          type="email" 
          required 
          autocomplete="email" 
          placeholder="teacher@example.com"
        />

        <label for="password">Password</label>
        <input 
          id="password" 
          name="password" 
          type="password" 
          required 
          autocomplete="current-password" 
          placeholder="Enter password"
        />

        <button type="submit">Login</button>
      </form>

      <button class="link-button" type="button" onclick="toggleReset()">
        Forgot password?
      </button>

      <div id="resetBox" class="reset-box">
        <form method="POST" action="/teacher/reset-request">
          <label for="resetEmail">Reset email</label>
          <input 
            id="resetEmail" 
            name="email" 
            type="email" 
            required 
            placeholder="Enter your teacher email"
          />

          <button type="submit">Send reset email</button>
          <p class="small">
            If this email exists, a reset link will be sent.
          </p>
        </form>
      </div>
    </div>
  </div>

  <script>
    function toggleReset() {
      const box = document.getElementById("resetBox");
      box.style.display = box.style.display === "block" ? "none" : "block";
    }
  </script>
</body>
</html>