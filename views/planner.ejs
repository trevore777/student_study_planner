<section class="page-header">
  <div>
    <h1>Two-Week Planner</h1>
    <p class="lede">Plan homework for this week and next week. Use multi-day planning for big tasks or memorisation.</p>
  </div>
</section>

<section class="planner-layout">
  <aside class="card planner-left">
    <div class="section-heading">
      <h2>Open homework</h2>
    </div>
    <p class="muted">Select a task, then choose single-day or multi-day planning.</p>
    <div id="plannerTaskList" class="task-list empty-state">
      <p>No open tasks to plan yet.</p>
    </div>
  </aside>

  <main class="planner-center">
    <section class="card planner-selected-task">
      <h2>Selected task</h2>
      <div id="selectedTaskPanel" class="muted">
        No task selected. Tap a homework task to begin planning.
      </div>

      <hr>

      <h3>Planning options</h3>

      <label>
        Schedule type
        <select id="scheduleType">
          <option value="single">Single day</option>
          <option value="multi">Spread over multiple days</option>
        </select>
      </label>

      <label>
        Study type
        <select id="studyType">
          <option value="homework">Homework</option>
          <option value="revision">Revision</option>
          <option value="memorisation">Memorisation</option>
          <option value="assignment">Assignment / big task</option>
          <option value="reading">Reading</option>
          <option value="exam-prep">Exam preparation</option>
        </select>
      </label>

      <label>
        Minutes per day
        <input id="dailyMinutes" type="number" min="5" value="20">
      </label>

      <div id="multiDayOptions" style="display:none;">
        <label>
          Start date
          <input id="multiStartDate" type="date">
        </label>

        <label>
          End date
          <input id="multiEndDate" type="date">
        </label>

        <button class="button primary" type="button" id="addMultiDayTask">
          Add across multiple days
        </button>
      </div>
    </section>

    <h2>This Week</h2>
    <section class="planner-grid" id="plannerWeekGridThis">
      <% ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'].forEach(day => { %>
        <section class="card planner-day" data-day-card="<%= day %>" data-week-offset="0">
          <div class="planner-day-header">
            <div>
              <h3><%= day %></h3>
              <p class="muted planner-day-date" data-day-date="<%= day %>" data-week-offset="0"></p>
            </div>
            <button class="button small" type="button" data-action="quick-add-day" data-day="<%= day %>" data-week-offset="0">
              Add selected
            </button>
          </div>
          <div class="planner-day-list task-list" data-day="<%= day %>" data-week-offset="0">
            <p>No study blocks planned.</p>
          </div>
        </section>
      <% }) %>
    </section>

    <h2 style="margin-top:2rem;">Next Week</h2>
    <section class="planner-grid" id="plannerWeekGridNext">
      <% ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'].forEach(day => { %>
        <section class="card planner-day" data-day-card="<%= day %>" data-week-offset="1">
          <div class="planner-day-header">
            <div>
              <h3><%= day %></h3>
              <p class="muted planner-day-date" data-day-date="<%= day %>" data-week-offset="1"></p>
            </div>
            <button class="button small" type="button" data-action="quick-add-day" data-day="<%= day %>" data-week-offset="1">
              Add selected
            </button>
          </div>
          <div class="planner-day-list task-list" data-day="<%= day %>" data-week-offset="1">
            <p>No study blocks planned.</p>
          </div>
        </section>
      <% }) %>
    </section>
  </main>

  <aside class="card planner-right">
    <h2>Planning reminders</h2>
    <ul class="tight-list">
      <li>Plan overdue tasks first</li>
      <li>Spread big tasks over several days</li>
      <li>Memorisation works better with short daily practice</li>
      <li>Leave review blocks before assessments</li>
      <li>Do not overload one night</li>
    </ul>
  </aside>
</section>

<script src="/client/db.js"></script>
<script src="/client/planner.js"></script>