<section class="page-header">
  <div>
    <h1>Weekly Planner</h1>
    <p class="lede">Tap a task, then tap a day to plan it quickly.</p>
  </div>
</section>

<section class="planner-layout">
  <aside class="card planner-left">
    <div class="section-heading">
      <h2>Open homework</h2>
    </div>
    <p class="muted">Tap a task, then tap a day in the week planner.</p>
    <div id="plannerTaskList" class="task-list empty-state">
      <p>No open tasks to plan yet.</p>
    </div>
  </aside>

  <main class="planner-center">
    <section class="card planner-selected-task">
      <h2>Selected task</h2>
      <div id="selectedTaskPanel" class="muted">
        No task selected. Tap a homework task to begin planning.
      </div>
    </section>

    <section class="planner-grid" id="plannerWeekGrid">
      <% ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'].forEach(day => { %>
        <section class="card planner-day" data-day-card="<%= day %>">
          <div class="planner-day-header">
            <div>
              <h3><%= day %></h3>
              <p class="muted planner-day-date" data-day-date="<%= day %>"></p>
            </div>
            <button
              class="button small"
              type="button"
              data-action="quick-add-day"
              data-day="<%= day %>"
            >
              Add selected
            </button>
          </div>

          <div class="planner-day-list task-list" data-day="<%= day %>">
            <p>No study blocks planned.</p>
          </div>
        </section>
      <% }) %>
    </section>
  </main>

  <aside class="card planner-right">
    <h2>Planning reminders</h2>
    <ul class="tight-list">
      <li>Plan overdue tasks first</li>
      <li>Put harder work earlier in the week</li>
      <li>Leave shorter review blocks before assessments</li>
      <li>Do not overload one night</li>
    </ul>

    <div class="card" style="margin-top: 1rem;">
      <h3>Quick tip</h3>
      <p class="muted">
        A short study block completed is better than a long study block delayed.
      </p>
    </div>
  </aside>
</section>

<script src="/client/db.js"></script>
<script src="/client/planner.js"></script>