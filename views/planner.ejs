<section class="page-header">
  <div>
    <h1>Weekly Planner</h1>
    <p class="lede">Turn homework into realistic study blocks across the week.</p>
  </div>
</section>

<section class="card">
  <h2>Plan your week</h2>
  <p class="muted">
    Use this page to spread your homework across the week. Start with what is overdue,
    then what is due soon, then add revision.
  </p>
</section>

<section class="planner-grid">
  <% ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'].forEach(day => { %>
    <section class="card planner-day">
      <h3><%= day %></h3>

      <div class="planner-block">
        <strong>After school</strong>
        <p class="muted">Quick check of homework and teacher posts</p>
      </div>

      <div class="planner-block">
        <strong>Homework block</strong>
        <p class="muted">Complete one priority task</p>
      </div>

      <div class="planner-block">
        <strong>Revision block</strong>
        <p class="muted">10–20 minutes of review or self-testing</p>
      </div>

      <button class="button small">Add study block</button>
    </section>
  <% }) %>
</section>

<section class="grid">
  <article class="card">
    <h2>Good planning habits</h2>
    <ul class="tight-list">
      <li>Start with overdue or due soon tasks</li>
      <li>Break big homework into smaller sessions</li>
      <li>Leave space for sport, family, and rest</li>
      <li>Do a short review before assessments</li>
    </ul>
  </article>

  <article class="card">
    <h2>Suggested routine</h2>
    <ul class="tight-list">
      <li>5 mins: check tasks</li>
      <li>20–30 mins: complete one task</li>
      <li>10 mins: review notes or quiz yourself</li>
      <li>2 mins: record what you finished</li>
    </ul>
  </article>
</section>