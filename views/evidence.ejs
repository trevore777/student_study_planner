<section class="page-header">
  <div>
    <h1>Evidence Log</h1>
    <p class="lede">Show what you have done in a simple digital format.</p>
  </div>
</section>

<section class="grid dashboard-grid">
  <article class="card">
    <h2>Add evidence</h2>

    <form id="evidenceForm" class="stack-form">
      <div class="field">
        <label for="taskId">Linked task</label>
        <select id="taskId" name="taskId" required>
          <option value="">Select a task</option>
        </select>
      </div>

      <div class="field">
        <label for="evidenceType">Evidence type</label>
        <select id="evidenceType" name="evidenceType" required>
          <option value="">Select type</option>
          <option value="reflection">Reflection note</option>
          <option value="screenshot">Screenshot record</option>
          <option value="photo">Photo record</option>
          <option value="completion">Completion note</option>
        </select>
      </div>

      <div class="field">
        <label for="evidenceText">What did you complete?</label>
        <textarea
          id="evidenceText"
          name="evidenceText"
          rows="5"
          placeholder="e.g. Finished questions 1–8, corrected mistakes, and reviewed the key terms."
          required
        ></textarea>
      </div>

      <div class="actions">
        <button class="button primary" type="submit">Save evidence</button>
      </div>
    </form>
  </article>

  <article class="card">
    <h2>Why evidence matters</h2>
    <ul class="tight-list">
      <li>Shows what was actually completed</li>
      <li>Builds student accountability</li>
      <li>Helps students reflect on progress</li>
      <li>Can later support teacher or parent summaries</li>
    </ul>
  </article>
</section>

<section class="card">
  <div class="section-heading">
    <h2>Saved evidence</h2>
  </div>
  <div id="evidenceList" class="task-list empty-state">
    <p>No evidence added yet.</p>
  </div>
</section>

<script src="/client/db.js"></script>
<script src="/client/evidence.js"></script>