<section class="page-header">
  <div>
    <h1>Post Homework</h1>
    <p class="lede">Publish homework in a way that is ready for multiple schools later.</p>
  </div>
</section>

<section class="card">
  <form method="POST" action="/teacher/homework/new" class="stack-form">
    <div class="field">
      <label for="schoolId">School</label>
      <select id="schoolId" name="schoolId" required>
        <% schools.forEach(school => { %>
          <option value="<%= school.id %>" <%= school.id === defaults.schoolId ? 'selected' : '' %>>
            <%= school.name %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="field">
      <label for="teacherId">Teacher</label>
      <select id="teacherId" name="teacherId" required>
        <% teachers.forEach(teacher => { %>
          <option value="<%= teacher.id %>" <%= teacher.id === defaults.teacherId ? 'selected' : '' %>>
            <%= teacher.name %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="field">
      <label for="classId">Class</label>
      <select id="classId" name="classId" required>
        <% classes.forEach(classItem => { %>
          <option value="<%= classItem.id %>" <%= classItem.id === defaults.classId ? 'selected' : '' %>>
            <%= classItem.name %><%= classItem.year_level ? ` (Year ${classItem.year_level})` : '' %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="field">
      <label for="subject">Subject</label>
      <input id="subject" name="subject" type="text" placeholder="e.g. English" required />
    </div>

    <div class="field">
      <label for="title">Homework title</label>
      <input id="title" name="title" type="text" placeholder="e.g. Complete persuasive paragraph" required />
    </div>

    <div class="field">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="5" placeholder="Instructions, page numbers, checklist..." required></textarea>
    </div>

    <div class="field">
      <label for="dueDate">Due date</label>
      <input id="dueDate" name="dueDate" type="date" required />
    </div>

    <div class="field">
      <label for="estimatedMinutes">Estimated minutes</label>
      <input id="estimatedMinutes" name="estimatedMinutes" type="number" min="5" step="5" value="20" />
    </div>

    <div class="actions">
      <button class="button primary" type="submit">Publish homework</button>
      <a class="button" href="/teacher/dashboard">Cancel</a>
    </div>
  </form>
</section>