<h1>Post Homework</h1>

<% if (error) { %>
  <p style="color:red;"><%= error %></p>
<% } %>

<% if (!classes.length) { %>
  <p>You need to add a class before posting homework.</p>
  <p><a href="/teacher/classes/new">Add Class</a></p>
<% } else { %>
  <form method="POST" action="/teacher/homework/new">
    <label>Class</label><br>
    <select name="classId" required>
      <% classes.forEach((cls) => { %>
        <option value="<%= cls.id %>"><%= cls.name %> — Year <%= cls.year_level %></option>
      <% }) %>
    </select><br><br>

    <label>Subject</label><br>
    <input type="text" name="subject" required><br><br>

    <label>Title</label><br>
    <input type="text" name="title" required><br><br>

    <label>Description</label><br>
    <textarea name="description" rows="5" required></textarea><br><br>

    <label>Due Date</label><br>
    <input type="date" name="dueDate" required><br><br>

    <label>Estimated Minutes</label><br>
    <input type="number" name="estimatedMinutes" value="20" min="5"><br><br>

    <button type="submit">Post Homework</button>
  </form>
<% } %>

<p><a href="/teacher/dashboard">Back to Dashboard</a></p>