<section class="page-header">
  <div>
    <h1>Subjects</h1>
    <p class="lede">Create and manage the subjects used in your planner.</p>
  </div>
</section>

<section class="grid dashboard-grid">
  <article class="card">
    <h2>Add subject</h2>

    <form id="subjectForm" class="stack-form">
      <div class="field">
        <label for="subjectName">Subject name</label>
        <input
          id="subjectName"
          name="subjectName"
          type="text"
          placeholder="e.g. English"
          required
        />
      </div>

      <div class="actions">
        <button class="button primary" type="submit">Save subject</button>
      </div>
    </form>
  </article>

  <article class="card">
    <h2>How subjects help</h2>
    <ul class="tight-list">
      <li>Keep homework organised correctly</li>
      <li>Make the dashboard easier to scan</li>
      <li>Help build a balanced weekly planner</li>
      <li>Prepare for teacher-posted tasks later</li>
    </ul>
  </article>
</section>

<section class="card">
  <div class="section-heading">
    <h2>Your subjects</h2>
  </div>
  <div id="subjectsList" class="task-list empty-state">
    <p>No subjects yet.</p>
  </div>
</section>

<script src="/client/db.js"></script>
<script src="/client/subjects.js"></script>